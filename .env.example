# Referensi variabel untuk Vercel / lokal. Aplikasi Next dijalankan dari folder app/;
# salin nilai ke app/.env.local atau ke dashboard Vercel (Root Directory = app).
# Panduan lengkap: DEPLOY.md

# Frontend (publik — aman di bundle klien)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only (jangan NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=

# Pilot (F7-2): AUTH_SIGNUP_MODE=open|closed|email_domain ; AUTH_SIGNUP_ALLOWED_EMAIL_DOMAIN=@…
# NEXT_PUBLIC_SHOW_PILOT_BANNER=1

# Opsional
APP_ENV=dev
APP_NAME=spatial-pm

